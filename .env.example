DATABASE_URL=file:./prisma/dev.db

# Backend
API_HOST=0.0.0.0
API_PORT=4000

# Frontend rewrite target (set for split deploy/dev with separate API process)
# Leave empty for single-service deploy (Railway root + unified server).
API_INTERNAL_ORIGIN=http://localhost:4000

# Dataset path for local reseeding only (or optional Railway runtime seeding)
SAP_O2C_DATASET_DIR=

# LLM
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_SQL_TIMEOUT_MS=20000
